<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Feedback Form</h1>
          <p class="subtle">Tell us how this event went — your input helps improve future events.</p>
        </div>
        <div class="panel-inner">
          <form class="feedback-grid" method="post" action="/feedback/<%= eventId %>">
            <div class="feedback-question">
              <p>Do you want your response to be anonymous?</p>
              <div class="feedback-options">
                <label class="rating-pill"><input type="radio" name="isAnonymous" value="1">Yes</label>
                <label class="rating-pill"><input type="radio" name="isAnonymous" value="0" checked>No</label>
              </div>
            </div>

            <div class="feedback-question">
              <p>How would you rate your overall experience? (1-5)</p>
              <div class="feedback-options">
                <% ratings.forEach((r) => { %>
                  <label class="rating-pill"><input type="radio" id="rating-<%= r %>" name="rating" value="<%= r %>" required><%= r %></label>
                <% }) %>
              </div>
            </div>

            <div class="feedback-question">
              <p>How likely are you to attend similar events in the future?</p>
              <div class="feedback-options">
                <% ratings.forEach((r) => { %>
                  <label class="rating-pill"><input type="radio" id="attend-<%= r %>" name="attend" value="<%= r %>" required><%= r %></label>
                <% }) %>
              </div>
            </div>

            <div class="feedback-question">
              <p>How likely are you to recommend this event to a friend or colleague?</p>
              <div class="feedback-options">
                <% ratings.forEach((r) => { %>
                  <label class="rating-pill"><input type="radio" id="recommend-<%= r %>" name="recommend" value="<%= r %>" required><%= r %></label>
                <% }) %>
              </div>
            </div>

            <div class="feedback-question">
              <p>Did this event help you achieve your goals (e.g., networking)?</p>
              <div class="feedback-options">
                <% ratings.forEach((r) => { %>
                  <label class="rating-pill"><input type="radio" id="goals-<%= r %>" name="goals" value="<%= r %>" required><%= r %></label>
                <% }) %>
              </div>
            </div>

            <div class="feedback-question">
              <label for="feedback">Any other feedback?</label>
              <textarea id="feedback" name="feedback"></textarea>
            </div>

            <div class="form-actions">
              <button class="btn btn-primary" type="submit">Submit Feedback</button>
              <a class="btn btn-ghost" href="/reserve/reservation">Back</a>
            </div>
          </form>
        </div>
      </div>
    </div>
</body>
</html>