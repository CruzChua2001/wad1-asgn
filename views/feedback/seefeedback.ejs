<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Feedback</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Feedback Details</h1>
          <p class="subtle">Review your submitted response.</p>
        </div>
        <div class="panel-inner stack">
          <% if (!feedback) { %>
            <div class="note note-danger text-danger">Feedback not found.</div>
            <a class="btn btn-ghost btn-sm" href="/feedback/history">Back to History</a>
          <% } else { %>
            <div class="feedback-question">
              <h2><%= feedback.EventName || "Unknown Event" %></h2>
              <div class="movie-meta">
                <span class="pill">Date: <%= feedback.CreatedDateTime.toLocaleString() %></span>
                <span class="pill">Anonymous: <%= feedback.isAnonymous == 1 ? "Yes" : "No" %></span>
                <span class="pill">Feedback ID: <%= feedback.FeedbackID %></span>
              </div>
            </div>

            <div class="metric-grid">
              <div class="metric-card">
                <div class="label">Overall Rating</div>
                <div class="value"><%= feedback.rating %><span class="label"> / 5</span></div>
              </div>
              <div class="metric-card">
                <div class="label">Attend Similar</div>
                <div class="value"><%= feedback.attend %><span class="label"> / 5</span></div>
              </div>
              <div class="metric-card">
                <div class="label">Recommend</div>
                <div class="value"><%= feedback.recommend %><span class="label"> / 5</span></div>
              </div>
              <div class="metric-card">
                <div class="label">Goals Achieved</div>
                <div class="value"><%= feedback.goals %><span class="label"> / 5</span></div>
              </div>
            </div>

            <div class="feedback-question">
              <label>Additional Feedback</label>
              <p><%= feedback.Feedback || "No additional feedback." %></p>
            </div>

            <div class="form-actions">
              <a class="btn btn-primary btn-sm" href="/feedback/edit/<%= feedback.FeedbackID %>">Edit Feedback</a>
              <form action="/feedback/delete/<%= feedback.FeedbackID %>" method="POST">
                <button class="btn btn-danger btn-sm" type="submit">Delete Feedback</button>
              </form>
              <a class="btn btn-ghost btn-sm" href="/feedback/history">Back to History</a>
            </div>
          <% } %>
        </div>
      </div>
    </div>

</body>
</html>