<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Feedback</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Edit Feedback</h1>
          <p class="subtle">Update your response for <%= feedback ? (feedback.EventName || "this event") : "this event" %>.</p>
        </div>
        <div class="panel-inner">
          <% if (!feedback) { %>
            <div class="note note-danger text-danger">Feedback not found.</div>
          <% } else { %>
            <form class="feedback-grid" action="/feedback/edit/<%= feedback.FeedbackID %>" method="POST">
              <div class="feedback-question">
                <p>Do you want your response to be anonymous?<b style="color:red">*</b></p>
                <div class="feedback-options">
                  <label class="rating-pill"><input type="radio" name="isAnonymous" value="1" <%= feedback.isAnonymous == 1 ? "checked" : "" %>>Yes</label>
                  <label class="rating-pill"><input type="radio" name="isAnonymous" value="0" <%= feedback.isAnonymous == 0 ? "checked" : "" %>>No</label>
                </div>
              </div>

              <div class="feedback-question">
                <p>How would you rate your overall experience?<b style="color:red">*</b></p>
                <div class="feedback-options">
                  <% ratings.forEach((r) => { %>
                    <label class="rating-pill"><input type="radio" id="rating-<%= r %>" name="rating" value="<%= r %>" <%= feedback.rating == r ? "checked" : "" %> required><%= r %></label>
                  <% }) %>
                </div>
              </div>

              <div class="feedback-question">
                <p>How likely are you to attend similar events in the future?<b style="color:red">*</b></p>
                <div class="feedback-options">
                  <% ratings.forEach((r) => { %>
                    <label class="rating-pill"><input type="radio" id="attend-<%= r %>" name="attend" value="<%= r %>" <%= feedback.attend == r ? "checked" : "" %> required><%= r %></label>
                  <% }) %>
                </div>
              </div>

              <div class="feedback-question">
                <p>How likely are you to recommend this event to a friend or colleague?<b style="color:red">*</b></p>
                <div class="feedback-options">
                  <% ratings.forEach((r) => { %>
                    <label class="rating-pill"><input type="radio" id="recommend-<%= r %>" name="recommend" value="<%= r %>" <%= feedback.recommend == r ? "checked" : "" %> required><%= r %></label>
                  <% }) %>
                </div>
              </div>

              <div class="feedback-question">
                <p>Did this event help you achieve your goals (e.g., networking)?<b style="color:red">*</b></p>
                <div class="feedback-options">
                  <% ratings.forEach((r) => { %>
                    <label class="rating-pill"><input type="radio" id="goals-<%= r %>" name="goals" value="<%= r %>" <%= feedback.goals == r ? "checked" : "" %> required><%= r %></label>
                  <% }) %>
                </div>
              </div>

              <div class="feedback-question">
                <label for="feedback">Additional feedback</label>
                <textarea id="feedback" name="feedback"><%= feedback.Feedback %></textarea>
              </div>

              <% if (errors && errors.length > 0) { %>
                <div class="note note-danger">
                  <ul>
                    <% errors.forEach(error => { %>
                      <li><%= error %></li>
                    <% }) %>
                  </ul>
                </div>
              <% } %>

              <div class="form-actions">
                <button class="btn btn-primary" type="submit">Save Changes</button>
                <a class="btn btn-ghost" href="/feedback/seefeedback/<%= feedback.FeedbackID %>">Cancel</a>
              </div>
            </form>
          <% } %>
        </div>
      </div>
    </div>

</body>
</html>