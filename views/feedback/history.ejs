<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>My Feedback History</h1>
          <p class="subtle">A timeline of feedback you submitted for past events.</p>
        </div>
        <div class="panel-inner stack">

          <% if (typeof history === "undefined" || history.length === 0) { %>
            <div class="note center">No feedback history found.</div>
          <% } else { %>
            <div class="event-list">
              <% history.forEach((item) => { %>
                <article class="event-card">
                  <div class="event-thumb">
                    <div class="event-thumb-placeholder">Feedback</div>
                  </div>
                  <div class="event-info stack">
                    <h2><%= item.EventName || "Unknown Event" %></h2>
                    <div class="meta">
                      <span class="pill">Submitted: <%= item.CreatedDateTime %></span>
                      <span class="pill">Feedback ID: <%= item.FeedbackID %></span>
                    </div>
                    <div class="movie-actions">
                      <a class="btn btn-ghost btn-sm" href="/feedback/seefeedback/<%= item.FeedbackID %>">View Feedback</a>
                      <a class="btn btn-primary btn-sm" href="/feedback/edit/<%= item.FeedbackID %>">Edit</a>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
</body>
</html>