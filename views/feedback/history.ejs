<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>My Feedback History</h1>
          <p class="subtle">A timeline of feedback you submitted for past events.</p>
        </div>
        <div class="panel-inner stack">

          <% if (typeof history === "undefined" || history.length === 0) { %>
            <div class="note center">No feedback history found.</div>
          <% } else { %>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Feedback ID</th>
                    <th>Event</th>
                    <th>Submitted On</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% history.forEach((item) => { %>
                    <tr>
                      <td><%= item.FeedbackID %></td>
                      <td><%= item.EventName || "Unknown Event" %></td>
                      <td><%= item.CreatedDateTime.toLocaleString() %></td>
                      <td>
                        <div class="row">
                          <a class="btn btn-ghost btn-sm" href="/feedback/seefeedback/<%= item.FeedbackID %>">View</a>
                          <a class="btn btn-primary btn-sm" href="/feedback/edit/<%= item.FeedbackID %>">Edit</a>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
</body>
</html>