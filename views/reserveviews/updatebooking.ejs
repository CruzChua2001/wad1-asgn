<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container stack">
        <div class="panel">
            <div class="panel-header">
                <h1>Event Reservation</h1>
                <p class="subtle"><%= reservation.EventDetails?.EventName || 'Unknown Event' %> · <%= formatDateTime(reservation.CreatedDateTime) || 'Unknown Date' %></p>
            </div>
            <div class="panel-inner stack">
                <div class="row">
                    <span class="pill">Remaining capacity: <%= reservation.EventDetails && typeof reservation.EventDetails.MaxCapacity === 'number' && typeof reservation.EventDetails.CurrentCapacity === 'number' ? (reservation.EventDetails.MaxCapacity - reservation.EventDetails.CurrentCapacity) : 'Unknown Capacity' %></span>
                    <span class="pill">Status: <%= reservation.Status || 'Unknown Booked' %></span>
                </div>

                                <% 
                                    let remaining = reservation.EventDetails && typeof reservation.EventDetails.MaxCapacity === 'number' && typeof reservation.EventDetails.CurrentCapacity === 'number' 
                                        ? (reservation.EventDetails.MaxCapacity - reservation.EventDetails.CurrentCapacity) 
                                        : null;
                                    if (remaining !== null && remaining <= 0) { %>
                                        <div class="note note-danger text-danger"><strong>Notice:</strong> This event is full or does not have enough space for your request. If you update now, you may be placed on the waitlist.</div>
                                <% } %>

                <form id="updateReservationForm" class="reserve-form" data-reservation-id="<%= reservation.ReservationID %>">
                    <input type="hidden" name="EventId" value="<%= reservation.EventId %>">
                    <label for="numofppl">Number of people attending:</label>
                    <input 
                    type="number" 
                    id="numofppl" 
                    class="reserve-input"
                    name="numofppl" 
                    min="1" 
                    step="1"
                    inputmode="numeric"
                    pattern="[0-9]+"
                    value="<%= reservation.numofppl || 1 %>"
                    required
                    >
                    <button class="btn btn-primary btn-sm" type="submit">Confirm</button>
                </form>

                <br>
                <a class="btn btn-ghost btn-sm" href="/reserve/reservation">Back</a>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById("updateReservationForm");
        form.addEventListener("submit", async (e) => {
            const input = document.getElementById('numofppl');
            const value = parseInt(input.value, 10);
            if (isNaN(value) || value < 1) {
                alert('Please enter a valid number greater than 0.');
                e.preventDefault();
                return;
            }
            // ...existing code...
            e.preventDefault();
            const reservationId = form.dataset.reservationId;
            const numofppl = input.value.trim();
            if (!/^\d+$/.test(numofppl)) {
                alert("Please enter numbers only.");
                return;
            }
            try {
                const response = await fetch(`/reserve/update/${reservationId}`, {
                    method: "PATCH",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded"
                    },
                    body: new URLSearchParams({ numofppl })
                });
                const result = await response.json();
                if (!response.ok) {
                    alert(result.message || "Failed to update booking.");
                    return;
                }
                window.location.href = "/reserve/reservation";
            } catch (err) {
                alert("Failed to update booking.");
            }
        });
    </script>
</body>
</html>