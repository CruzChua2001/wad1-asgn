<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include('../partials/navbar') %>
     <% if (reservations) { %>
        <h1>Welcome <%= userId %></h1>
    <% } %>

  <table border="1">
    <tr>
        <th>Event</th>
        <th>Pax</th>
        <th>Date</th>
        <th>Time</th>
        <th>Status</th>
        <th>Update</th>
        <th>Cancel</th>
    </tr>
    <% reservations.forEach(reservation => { %>
        <% if (reservation.EventDetails?.EventID == reservation.EventId) { %>
        <tr>
            <td><%= reservation.EventDetails.EventName %></td>
            <td style="text-align: center;"><%= reservation.numofppl %></td>
                <% 
                    const eventDate = new Date(reservation.CreatedDateTime);
                    // Format the date (e.g., 16/03/2026)
                    const formattedDate = eventDate.toLocaleDateString('en-GB'); 
                    // Format the time (e.g., 10:33:24 am)
                    const formattedTime = eventDate.toLocaleTimeString('en-US', { 
                        hour: '2-digit', 
                        minute: '2-digit',
                        hour12: true 
                    });
                %>
            
            <td><%= formattedDate %></td>
            <td><%= formattedTime %></td>
            <td><%= reservation.Status %></td>
            <td><a href="/reserve/update/<%= reservation.ReservationID %>">Update</a></td>
            <td>
                <button
                    type="button"
                    class="cancel-booking-btn"
                    data-reservation-id="<%= reservation.ReservationID %>">
                    Cancel
                </button>
            </td>
            <% } %>
        </tr>
    <% }); %>
    
  </table>

  <script>
    document.querySelectorAll(".cancel-booking-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
            const reservationId = btn.dataset.reservationId;
            const shouldCancel = confirm("Cancel this booking?");
            if (!shouldCancel) return;

            try {
                const response = await fetch(`/reserve/delete/${reservationId}`, {
                    method: "DELETE"
                });
                const result = await response.json();

                if (!response.ok) {
                    alert(result.message || "Failed to cancel booking.");
                    return;
                }
                window.location.reload();
            } catch (err) {
                alert("Failed to cancel booking.");
            }
        });
    });
  </script>

</body>
</html>