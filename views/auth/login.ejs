<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login – Campus Event Board</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>

    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Login</h1>
          <p class="subtle">Welcome back. Pick up where you left off.</p>
        </div>
        <div class="panel-inner stack">

      <% if (error) { %>
          <div class="note note-danger text-danger"><%= error %></div>
      <% } %>

      <form method="POST" action="/login">
          <label for="email">Email</label><br>
          <input type="email" id="email" name="email" required><br><br>

          <label for="password">Password</label><br>
          <input type="password" id="password" name="password" required><br><br>

          <button class="btn btn-primary" type="submit">Login</button>
      </form>

      <p><a class="link" href="/forgotpassword">Forgot password?</a></p>
      <p class="subtle">Don't have an account? <a class="link" href="/register">Register here</a></p>
        </div>
      </div>
    </div>
</body>
</html>