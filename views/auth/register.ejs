<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register – Campus Event Board</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    
    <div class="container stack">
        <div class="panel">
            <div class="panel-header">
                <h1>Create Account</h1>
                <p class="subtle">Join the board and start booking events.</p>
            </div>
            
            <div class="panel-inner stack">

            <% if (error) { %>
                <div class="note note-danger text-danger"><%= error %></div>
            <% } %>

            <% if (success) { %>
                <div class="note note-success text-success"><%= success %></div>
            <% } %>

            <form method="POST" action="/register">
                <label for="firstName">First Name</label><br>
                <input type="text" id="firstName" name="firstName" required><br><br>

                <label for="lastName">Last Name</label><br>
                <input type="text" id="lastName" name="lastName" required><br><br>

                <label for="email">Email</label><br>
                <input type="email" id="email" name="email" required><br><br>

                <label for="password">Password</label><br>
                <input type="password" id="password" name="password" required><br><br>

                <label for="confirmPassword">Confirm Password</label><br>
                <input type="password" id="confirmPassword" name="confirmPassword" required><br><br>

                <button class="btn btn-primary" type="submit">Register</button>
            </form>

            <p class="subtle">Already have an account? <a class="link" href="/login">Login here</a></p>
            </div>
        </div>
    </div>
</body>
</html>