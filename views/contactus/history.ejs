<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report History</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <main class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Report History</h1>
          <p class="subtle">All reports submitted by users.</p>
        </div>
        <div class="panel-inner stack">
          <% if (reports.length === 0) { %>
              <div class="note">No reports submitted yet.</div>
          <% } else { %>
            <div class="event-list">
              <% reports.forEach(report => { %>
                <div class="event-card">
                  <div class="event-thumb">
                    <div class="event-thumb-placeholder">Report</div>
                  </div>
                  <div class="event-info stack">
                    <h2><%= report.Category %></h2>
                    <div class="meta">
                      <span class="pill">User: <%= report.UserID %></span>
                      <span class="pill">Status: <%= report.Status %></span>
                      <span class="pill">Submitted: <%= report.CreatedAt %></span>
                    </div>
                    <div class="movie-desc">
                      <%= report.Report %>
                    </div>
                    <div class="movie-actions">
                      <a class="btn btn-ghost btn-sm" href="/contactus/<%= report.ReportID %>">View</a>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
        <% } %>
      </div>
    </div>
    </main>
</body>
</html>