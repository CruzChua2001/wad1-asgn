<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report Detail</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <main class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Report Detail</h1>
          <p class="subtle">Case number: <%= report.CaseNo %></p>
        </div>
        <div class="panel-inner stack">

    <div class="row">
        <span class="pill">Category: <%= report.Category %></span>
        <span class="pill">Submitted by: <%= username %></span>
        <span class="pill">Status: <%= report.Status === "Not Applicable" ? "" : report.Status %></span>
        <span class="pill">Submitted: <%= report.CreatedAt.toLocaleString() %></span>
    </div>

        <% if (currentUserId === report.UserID) { %>
            <button class="btn-link text-danger" type="button" onclick="deleteReport('<%= report.ReportID %>')">Delete Report</button>
        <% } %>
        <% if (isAdmin && report.Status !== "Not Applicable") { %>
            <h3>Update Report Status</h3>
            <form action="/contactus/<%= report.ReportID %>/status" method="POST">
                <div class="status-row">
                    <select name="status" required>
                        <option value="">Select Status</option>
                        <option value="Pending" <%= report.Status === "Pending" ? "selected" : "" %>>Pending</option>
                        <option value="In-Progress" <%= report.Status === "In-Progress" ? "selected" : "" %>>In-Progress</option>
                        <option value="Solved" <%= report.Status === "Solved" ? "selected" : "" %>>Solved</option>
                    </select>
                    <button class="btn btn-primary btn-sm" type="submit">Update</button>
                </div>
            </form>
        <% } %>
    </div>
    <hr>

    <div>
        <b>Comment / Feedback:</b>
        <% if (currentUserId === report.UserID) { %>
            <button class="btn-link" type="button" onclick="displayEdit()">Edit</button>
        <% } %>
        <p><%= report.Report %></p>
        <textarea id="reportContent" class="hidden" cols="80" rows="4"><%= report.Report %></textarea>
        <button class="btn btn-ghost hidden" id="cancelBtn" onclick="cancelEdit()" type="button">Cancel</button>
        <button class="btn btn-primary hidden" id="saveBtn" onclick="saveReport('<%= report.ReportID %>')" type="button">Save</button>
    </div>

    <hr>

    <div>
        <h2>Reply</h2>
        <% if (report.Reply && report.Reply.length > 0) { %>
            <% report.Reply.forEach(reply => { %>
                <div class="panel mb-10">
                  <div class="panel-inner row-top">
                    <section>
                        <b><%= reply.UserID %></b> <br>
                        <%= reply.CreatedAt.toLocaleString() %>
                        <p><%= reply.Message %></p>

                        <!-- Editable reply -->
                        <textarea id="replyContent-<%= reply.ReplyID %>" class="hidden" cols="80" rows="4"><%= reply.Message %></textarea>
                        <button class="btn btn-ghost hidden" id="cancelReplyBtn-<%= reply.ReplyID %>" onclick="cancelEditReply('<%= reply.ReplyID %>')" type="button">Cancel</button>
                        <button class="btn btn-primary hidden" id="saveReplyBtn-<%= reply.ReplyID %>" onclick="saveReply('<%= report.ReportID %>', '<%= reply.ReplyID %>')" type="button">Save</button>
                    </section>
                    <div class="reply-actions">
                        <% if (reply.UserID === currentUserId) { %>
                            <button class="btn-link" type="button" onclick="displayEditReply('<%= reply.ReplyID %>')">Edit</button>
                            <button class="btn-link text-danger" type="button" onclick="deleteReply('<%= report.ReportID %>', '<%= reply.ReplyID %>')">Delete</button>
                        <% } %>
                    </div>
                  </div>
                </div>
            <% }); %>
        <% } else { %>
            <p>No reply from admin yet.</p>
        <% } %>
            
        <h3>Submit a Reply</h3>
        <form action="/contactus/<%= report.ReportID %>/reply" method="POST">
            <textarea name="message" rows="4" cols="50" required></textarea><br><br>
            <button class="btn btn-primary" type="submit">Submit Reply</button>
        </form>
    </div>
</div>
</div>
</main>
</body>
</html>

<script>
    const deleteReport = (reportId) => {
        if (confirm("Are you sure you want to delete this report?")) {
            fetch(`/contactus/${reportId}`, {
                method: 'DELETE'
            })
            .then(response => {
                if (response.ok) {
                    alert("Report deleted successfully.");
                    window.location.href = "/contactus";
                } else {
                    alert("Failed to delete report.");
                }
            })
            .catch(error => {
                console.error("Error deleting report:", error);
                alert("An error occurred while deleting the report.");
            });
        }
    };

    const displayEdit = () => {
        document.getElementById("cancelBtn").classList.remove("hidden");
        document.getElementById("reportContent").classList.remove("hidden");
        document.getElementById("saveBtn").classList.remove("hidden");
    };

    const cancelEdit = () => {
        document.getElementById("cancelBtn").classList.add("hidden");
        document.getElementById("reportContent").classList.add("hidden");
        document.getElementById("saveBtn").classList.add("hidden");
    };

    const saveReport = (reportId) => {
        const updatedContent = document.getElementById("reportContent").value;
        fetch(`/contactus/${reportId}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ report: updatedContent })
        })
        .then(response => {
            if (response.ok) {
                alert("Report updated successfully.");
                window.location.reload();
            } else {
                alert("Failed to update report.");
            }
        })
        .catch(error => {
            console.error("Error updating report:", error);
            alert("An error occurred while updating the report.");
        });
    };

    const deleteReply = (reportId, replyId) => {
        if (confirm("Are you sure you want to delete this reply?")) {
            fetch(`/contactus/${reportId}/${replyId}/reply`, {
                method: 'DELETE'
            })
            .then(response => {
                if (response.ok) {
                    alert("Reply deleted successfully.");
                    window.location.reload();
                } else {
                    alert("Failed to delete reply.");
                }
            })
            .catch(error => {
                console.error("Error deleting reply:", error);
                alert("An error occurred while deleting the reply.");
            });
        }
    };

    const displayEditReply = (replyId) => {
        document.getElementById(`cancelReplyBtn-${replyId}`).classList.remove("hidden");
        document.getElementById(`replyContent-${replyId}`).classList.remove("hidden");
        document.getElementById(`saveReplyBtn-${replyId}`).classList.remove("hidden");
    };

    const cancelEditReply = (replyId) => {
        document.getElementById(`cancelReplyBtn-${replyId}`).classList.add("hidden");
        document.getElementById(`replyContent-${replyId}`).classList.add("hidden");
        document.getElementById(`saveReplyBtn-${replyId}`).classList.add("hidden");
    };

    const saveReply = (reportId, replyId) => {
        const updatedMessage = document.getElementById(`replyContent-${replyId}`).value;
        fetch(`/contactus/${reportId}/${replyId}/reply`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ message: updatedMessage })
        })
        .then(response => {
            if (response.ok) {
                alert("Reply updated successfully.");
                window.location.reload();
            } else {
                alert("Failed to update reply.");
            }
        })
        .catch(error => {
            console.error("Error updating reply:", error);
            alert("An error occurred while updating the reply.");
        });
    };
</script>