<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report Detail</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <h1>Report Detail</h1>
    <span>Case Number: <%= report.CaseNo %></span>
    <br><br>

    <div>
        <span>Category: <%= report.Category %></span>
        <br>
        <span>Submitted By: <%= username %></span>
        <br>
        <span>Status: <%= report.Status === "Not Applicable" ? "" : report.Status %></span>
        <br>
        <span>Submitted On: <%= report.CreatedAt.toLocaleString() %></span>
        <br><br>
        <% if (currentUserId === report.UserID) { %>
            <span style="color:red; text-decoration: underline; cursor: pointer;" onclick="deleteReport('<%= report.ReportID %>')">Delete Report</span>
        <% } %>
        <% if (isAdmin && report.Status !== "Not Applicable") { %>
            <h3>Update Report Status</h3>
            <form action="/contactus/<%= report.ReportID %>/status" method="POST">
                <select name="status" required>
                    <option value="">Select Status</option>
                    <option value="Pending" <%= report.Status === "Pending" ? "selected" : "" %>>Pending</option>
                    <option value="In-Progress" <%= report.Status === "In-Progress" ? "selected" : "" %>>In-Progress</option>
                    <option value="Solved" <%= report.Status === "Solved" ? "selected" : "" %>>Solved</option>
                </select>
                <button type="submit">Update Status</button>
            </form>
        <% } %>
    </div>
    <br><hr><br>

    <div>
        <b>Comment / Feedback:</b>
        <% if (currentUserId === report.UserID) { %>
            <span style="text-decoration: underline; cursor: pointer; color: darkblue;" onclick="displayEdit()">Edit</span>
        <% } %>
        <p><%= report.Report %></p>
        <textarea id="reportContent" style="display:none;" cols="80" rows="4"><%= report.Report %></textarea>
        <button id="cancelBtn" onclick="cancelEdit()" style="display:none;" >Cancel</button>
        <button id="saveBtn" style="display:none;" onclick="saveReport('<%= report.ReportID %>')">Save</button>
    </div>

    <br><hr><br>

    <div>
        <h2>Reply</h2>
        <% if (report.Reply && report.Reply.length > 0) { %>
            <% report.Reply.forEach(reply => { %>
                <div style="border: 1px solid gray; padding: 5px; margin-bottom: 5px; display: flex; justify-content: space-between;">
                    <section>
                        <b><%= reply.UserID %></b> <br>
                        <%= reply.CreatedAt.toLocaleString() %>
                        <p><%= reply.Message %></p>

                        <!-- Editable reply -->
                        <textarea id="replyContent-<%= reply.ReplyID %>" style="display:none;" cols="80" rows="4"><%= reply.Message %></textarea>
                        <button id="cancelReplyBtn-<%= reply.ReplyID %>" onclick="cancelEditReply('<%= reply.ReplyID %>')" style="display:none;" >Cancel</button>
                        <button id="saveReplyBtn-<%= reply.ReplyID %>" style="display:none;" onclick="saveReply('<%= report.ReportID %>', '<%= reply.ReplyID %>')">Save</button>
                    </section>
                    <section>
                        <% if (reply.UserID === currentUserId) { %>
                            <span style="color:darkblue; text-decoration: underline; cursor: pointer;" onclick="displayEditReply('<%= reply.ReplyID %>')">Edit</span>
                            <span style="color:red; text-decoration: underline; cursor: pointer;" onclick="deleteReply('<%= report.ReportID %>', '<%= reply.ReplyID %>')">Delete</span>
                        <% } %>
                    </section>
                </div>
            <% }); %>
        <% } else { %>
            <p>No reply from admin yet.</p>
        <% } %>
            
        <h3>Submit a Reply</h3>
        <form action="/contactus/<%= report.ReportID %>/reply" method="POST">
            <textarea name="message" rows="4" cols="50" required></textarea><br><br>
            <button type="submit">Submit Reply</button>
        </form>
    </div>
</body>
</html>

<script>
    const deleteReport = (reportId) => {
        if (confirm("Are you sure you want to delete this report?")) {
            fetch(`/contactus/${reportId}`, {
                method: 'DELETE'
            })
            .then(response => {
                if (response.ok) {
                    alert("Report deleted successfully.");
                    window.location.href = "/contactus";
                } else {
                    alert("Failed to delete report.");
                }
            })
            .catch(error => {
                console.error("Error deleting report:", error);
                alert("An error occurred while deleting the report.");
            });
        }
    };

    const displayEdit = () => {
        document.getElementById("cancelBtn").style.display = "inline-block";
        document.getElementById("reportContent").style.display = "block";
        document.getElementById("saveBtn").style.display = "inline-block";
    };

    const cancelEdit = () => {
        document.getElementById("cancelBtn").style.display = "none";
        document.getElementById("reportContent").style.display = "none";
        document.getElementById("saveBtn").style.display = "none";
    };

    const saveReport = (reportId) => {
        const updatedContent = document.getElementById("reportContent").value;
        fetch(`/contactus/${reportId}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ report: updatedContent })
        })
        .then(response => {
            if (response.ok) {
                alert("Report updated successfully.");
                window.location.reload();
            } else {
                alert("Failed to update report.");
            }
        })
        .catch(error => {
            console.error("Error updating report:", error);
            alert("An error occurred while updating the report.");
        });
    };

    const deleteReply = (reportId, replyId) => {
        if (confirm("Are you sure you want to delete this reply?")) {
            fetch(`/contactus/${reportId}/${replyId}/reply`, {
                method: 'DELETE'
            })
            .then(response => {
                if (response.ok) {
                    alert("Reply deleted successfully.");
                    window.location.reload();
                } else {
                    alert("Failed to delete reply.");
                }
            })
            .catch(error => {
                console.error("Error deleting reply:", error);
                alert("An error occurred while deleting the reply.");
            });
        }
    };

    const displayEditReply = (replyId) => {
        document.getElementById(`cancelReplyBtn-${replyId}`).style.display = "inline-block";
        document.getElementById(`replyContent-${replyId}`).style.display = "block";
        document.getElementById(`saveReplyBtn-${replyId}`).style.display = "inline-block";
    };

    const cancelEditReply = (replyId) => {
        document.getElementById(`cancelReplyBtn-${replyId}`).style.display = "none";
        document.getElementById(`replyContent-${replyId}`).style.display = "none";
        document.getElementById(`saveReplyBtn-${replyId}`).style.display = "none";
    };

    const saveReply = (reportId, replyId) => {
        const updatedMessage = document.getElementById(`replyContent-${replyId}`).value;
        fetch(`/contactus/${reportId}/${replyId}/reply`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ message: updatedMessage })
        })
        .then(response => {
            if (response.ok) {
                alert("Reply updated successfully.");
                window.location.reload();
            } else {
                alert("Failed to update reply.");
            }
        })
        .catch(error => {
            console.error("Error updating reply:", error);
            alert("An error occurred while updating the reply.");
        });
    };
</script>