<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <main class="container stack">
    <div class="panel">
        <div class="panel-header">
            <h1>Contact Us</h1>
            <p class="subtle">Questions, bug reports, or feedback? Send it over — we’ll reply within 2–3 business days.</p>
        </div>
        <div class="panel-inner stack">
        <% if (submitted) { %>
         <div class="note note-success">
            <h3>Thank you for contacting us!</h3>
            <p>We’ll get back to you within 2 to 3 business days.</p>
            <p>Click <a class="link" href="/contactus">here</a> to submit another report.</p>
         </div>
        <% } else { %>
        <form action="/contactus" method="POST">
            <label for="category">Category*:</label><br>
            <select name="category" id="category" required style="height:35px; font-size:15px">
                <% reportTypes.forEach(type => { %>
                    <option value="<%= type %>"><%= type %></option>
                <% }) %>
            </select><br><br>

            <label for="report">Message*:</label><br>
            <textarea id="report" name="report" rows="5" cols="50" required></textarea><br><br>

            <% if (errors && errors.length > 0) { %>
                <div class="note note-error" style="margin-bottom: 15px;">
                    <b>Errors</b>
                    <ul>
                        <% errors.forEach(error => { %>
                            <li><%= error %></li>
                        <% }) %>
                    </ul>
                </div>
            <% } %>

            <button class="btn btn-primary" type="submit">Submit</button>
        </form>
        <% } %>

        <% if (!submitted) { %>
            <h2>Report Histories</h2>

            <div>
                <div class="search-row">
                    <input type="text" id="searchInput" placeholder="Search reports..." class="search-input">
                    <button class="btn btn-ghost btn-sm" id="searchBtn" type="button">Search</button>
                    <button class="btn btn-ghost btn-sm" id="clearSearchBtn" type="button">Clear Search</button>
                </div>
                
                <div class="row" style="margin-top:15px">
                    <select id="categoryFilter" style="padding: 8px; width: 150px; height: 30px; font-size:13px">
                        <option value="">All Categories</option>
                        <% reportTypes.forEach(type => { %>
                            <option value="<%= type %>"><%= type %></option>
                        <% }) %>
                    </select>

                    <select id="statusFilter" style="padding: 8px; margin-left: 10px; width: 150px; height: 30px; font-size:13px">
                        <option value="">All Statuses</option>
                        <% statusOptions.forEach(status => { %>
                            <option value="<%= status %>"><%= status %></option>
                        <% }) %>
                    </select>

                    <button class="btn btn-ghost btn-sm" id="filterBtn" type="button" style="margin-left: 10px;">Clear Filters</button>
                </div>
            </div>
            
            <% if (reports.length === 0) { %>
                <p>No reports submitted yet.</p>
            <% } else { %>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Report</th>
                                <th>Submitted On</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reports.forEach(report => { %>
                                <tr>
                                    <td><%= report.Category %></td>
                                    <td><%= report.Report %></td>
                                    <td><%= report.CreatedAt.toLocaleString() %></td>
                                    <td><%= report.Status === "Not Applicable" ? "" : report.Status %></td>
                                    <td>
                                        <div class="actions-col">
                                            <a class="btn btn-primary btn-sm" href="/contactus/<%= report.ReportID %>">View</a>
                                            <button class="btn btn-danger btn-sm delete-btn" data-id="<%= report.ReportID %>" type="button">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        <% } %>
        </div>
    </div>
    </main>
</body>
</html>

<script>
window.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const reportId = this.getAttribute('data-id');
            if (confirm('Are you sure you want to delete this report?')) {
                fetch(`/contactus/${reportId}`, {
                    method: 'DELETE'
                })
                .then(response => {
                    if (response.ok) {
                        alert('Report deleted successfully.');
                        window.location.replace("/contactus");
                    } else {
                        alert('Failed to delete the report.');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while deleting the report.');
                });
            }
        });
    });

    const searchBtn = document.getElementById('searchBtn');
    const clearSearchBtn = document.getElementById('clearSearchBtn');
    const searchInput = document.getElementById('searchInput');

    const categoryFilter = document.getElementById('categoryFilter');
    const statusFilter = document.getElementById('statusFilter');
    const clearFilterBtn = document.getElementById('filterBtn');

    const searchFn = () => {
        const query = searchInput.value.toLowerCase();
        const categoryValue = categoryFilter.value;
        const statusValue = statusFilter.value;

        const rows = document.querySelectorAll('table tbody tr');
        rows.forEach(row => {
            const reportText = row.cells[1].textContent.toLowerCase();
            const categoryText = row.cells[0].textContent;
            const statusText = row.cells[3].textContent;

            const matchesSearch = reportText.includes(query);
            const matchesCategory = categoryValue === '' || categoryText === categoryValue;
            const matchesStatus = statusValue === '' || statusText === statusValue;

            if (matchesSearch && matchesCategory && matchesStatus) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    };

    searchBtn.addEventListener('click', searchFn);

    searchInput.addEventListener('keypress', event => {
        if (event.key === 'Enter') {
            event.preventDefault();
            searchFn();
        }
    });

    clearSearchBtn.addEventListener('click', () => {
        searchInput.value = '';
        searchFn();
    });

    const filterFn = () => {
        const query = searchInput.value.toLowerCase();
        const categoryValue = categoryFilter.value;
        const statusValue = statusFilter.value;
        const rows = document.querySelectorAll('table tbody tr');
        rows.forEach(row => {
            const reportText = row.cells[1].textContent.toLowerCase();
            const categoryText = row.cells[0].textContent;
            const statusText = row.cells[3].textContent;    
            const matchesSearch = reportText.includes(query);
            const matchesCategory = categoryValue === '' || categoryText === categoryValue;
            const matchesStatus = statusValue === '' || statusText === statusValue;
            if (matchesSearch && matchesCategory && matchesStatus) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    };

    categoryFilter.addEventListener('change', filterFn);
    statusFilter.addEventListener('change', filterFn);

    clearFilterBtn.addEventListener('click', () => {
        categoryFilter.value = '';
        statusFilter.value = '';
        filterFn();
    });
});
</script>