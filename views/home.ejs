<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include('partials/navbar') %>
    <h1>Top events</h1>
    <table border="1">
        <th>Rank</th>
        <th>Event Name</th>
        <th>Average Score</th>
        <% if ( topEvents === undefined || topEvents.length === 0 ) { %>
                <tr>
                    <td colspan="4">No feedback available yet.</td>
                </tr>
            <% } else { %>
                <% topEvents.forEach((event, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= event.eventName %></td>
                        <td><%= event.avgScore.toFixed(2) %></td>
                    </tr>
                <% }) %>
            <% } %>
    </table>
</body>
</html>