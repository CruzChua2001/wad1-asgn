<!-- admin view of someone else's account, only admins can access the page -->

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Detail – Campus Event Board</title>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>User Detail</h1>
          <p class="subtle">Admin-only view of a user account.</p>
        </div>
        <div class="panel-inner stack">

          <p><strong>First Name:</strong> <%= user.FirstName %></p>
          <p><strong>Last Name:</strong> <%= user.LastName %></p>
          <p><strong>Email:</strong> <%= user.Email %></p>
          <p><strong>Role:</strong> <%= user.Role %></p>
          <p><strong>User ID:</strong> <%= user.UserID %></p>

          <div class="form-actions">
            <form method="POST" action="/user/<%= user.UserID %>/delete" class="inline">
                <button class="btn btn-danger" type="submit">Delete User</button>
            </form>
            <a class="btn btn-ghost" href="/user">Back to User List</a>
          </div>

        </div>
      </div>
    </div>
</body>
</html>