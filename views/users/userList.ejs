<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users – Campus Event Board</title>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container stack">
    <div class="panel">
      <div class="panel-header">
        <h1>Manage Users</h1>
        <p class="subtle">Review users and create an admin account.</p>
      </div>
      <div class="panel-inner stack">

    <% if (error) { %>
        <div class="note note-danger text-danger"><%= error %></div>
    <% } %>

    <div class="row-between">
      <div class="stack">
        <h3>Create Admin Account</h3>
        <p class="subtle">Open the form to add an admin.</p>
      </div>
      <button id="openAdminForm" class="btn btn-primary btn-sm" type="button">Add Admin</button>
    </div>

    <div id="adminFormWrap" class="form-card category-form hidden">
      <form method="POST" action="/user/admin" class="stack">
        <label for="firstName">First Name</label>
        <input type="text" id="firstName" name="firstName" required>

        <label for="lastName">Last Name</label>
        <input type="text" id="lastName" name="lastName" required>

        <label for="email">Email</label>
        <input type="email" id="email" name="email" required>

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required>

        <div class="form-actions">
          <button class="btn btn-primary btn-sm" type="submit">Create Admin</button>
          <button id="closeAdminForm" class="btn btn-ghost btn-sm" type="button">Cancel</button>
        </div>
      </form>
    </div>

    <div class="table-wrap">
      <table>
          <tr>
              <th>First Name</th>
              <th>Last Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Actions</th>
          </tr>
          <% users.forEach(user => { %>
              <tr>
                  <td><%= user.FirstName %></td>
                  <td><%= user.LastName %></td>
                  <td><%= user.Email %></td>
                  <td><%= user.Role %></td>
                  <td>
                      <a class="btn btn-ghost btn-sm" href="/user/<%= user.UserID %>">View</a>
                      <button class="btn btn-danger" type="button" onclick="confirmDelete('<%= user.UserID %>')">Delete</button>
                  </td>
              </tr>
          <% }) %>
      </table>
    </div>
      </div>
    </div>
    </div>

    <script>
      (function () {
        const openBtn = document.getElementById('openAdminForm');
        const closeBtn = document.getElementById('closeAdminForm');
        const wrap = document.getElementById('adminFormWrap');
        if (!openBtn || !closeBtn || !wrap) return;

        openBtn.addEventListener('click', () => wrap.classList.remove('hidden'));
        closeBtn.addEventListener('click', () => wrap.classList.add('hidden'));
      })();
    </script>
    <div id="deleteModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); align-items:center; justify-content:center;">
        <div style="background:white; padding:2rem; border-radius:8px; text-align:center;">
            <p style="color: black;">Are you sure you want to delete this user? This cannot be undone.</p>
            <br>
            <form id="deleteForm" method="POST" action="" style="display:inline;">
                <button type="submit">Yes, delete user</button>
            </form>
            <button onclick="document.getElementById('deleteModal').style.display='none'">Cancel</button>
        </div>
    </div>

    <script>
        function confirmDelete(userID) {
            document.getElementById('deleteForm').action = '/user/' + userID + '/delete';
            const modal = document.getElementById('deleteModal');
            modal.style.display = 'flex';
            modal.style.alignItems = 'center';
            modal.style.justifyContent = 'center';
        }
    </script>
</body>
</html>