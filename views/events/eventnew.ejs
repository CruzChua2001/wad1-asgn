<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Event</title>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Create New Event</h1>
          <p class="subtle">Add a new event to the board.</p>
        </div>
        <div class="panel-inner stack">

    <% if (errors && errors.length > 0) { %>
        <div class="note note-danger">
        <ul>
            <% errors.forEach(error => { %>
                <li class="text-danger"><%= error %></li>
            <% }) %>
        </ul>
        </div>
    <% } %>

    <form action="/event/new" method="POST" enctype="multipart/form-data" novalidate>
        <label for="EventImage">Event Image:</label><br>
        <input type="file" id="EventImage" name="EventImage" accept="image/*"><br><br>

        <label for="EventName">Event Name:</label><br>
        <input type="text" id="EventName" name="EventName" value="<%= formData?.EventName || '' %>"><br><br>

        <label for="EventDescription">Event Description:</label><br>
        <textarea id="EventDescription" name="EventDescription"><%= formData?.EventDescription || '' %></textarea><br><br>

        <label for="EventType">Event Type:</label><br>
        <select id="EventType" name="EventType" style="height:35px; font-size:15px">
            <option value="">Select Event Type</option>
            <% categories.forEach(category => { %>
                <option value="<%= category.CategoryID %>" 
                    <%= formData?.EventType == category.CategoryID ? 'selected' : '' %>>
                        <%= category.CategoryName %>
            </option>
            <% }) %>
        </select><br><br>

        <label for="MaxCapacity">Max Capacity:</label><br>
        <input type="number" id="MaxCapacity" name="MaxCapacity" value="<%= formData?.MaxCapacity || '' %>"><br><br>

        <label for="EndDateTime">End Date and Time:</label><br>
        <input type="datetime-local" id="EndDateTime" name="EndDateTime" onclick="if (this.showPicker) this.showPicker()" value="<%= formData?.EndDateTime || '' %>"><br><br>

        <div style="display:flex; align-items:center; gap:10px;">
            <button class="btn btn-primary" type="submit">Create Event</button>

            <span class="form-actions">
                <a class="btn btn-ghost" href="/event/manage">Cancel</a>
            </span>
        </div>
        
    </form>
    
        </div>
      </div>
    </div>
</body>
</html>