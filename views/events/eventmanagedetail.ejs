<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View and Update Event</title>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container stack">
      <div class="panel">
        <div class="panel-header row-between">
          <div>
            <h1>View & Update Event</h1>
            <p class="subtle">Make changes and hit Update.</p>
          </div>
          <span class="pill">ID: <%= event.EventID %></span>
        </div>

        <div class="panel-inner grid-2">
          <div class="movie-poster event-detail-image">
            <% if (event.EventImage) { %>
              <img src="<%= event.EventImage %>" alt="<%= event.EventName %> poster">
            <% } else { %>
              <div class="event-thumb-placeholder">No Image</div>
            <% } %>
          </div>

          <div class="form-card stack">
            <div class="stack">
              <label for="EventName">Event Name</label>
              <input type="text" id="EventName" name="EventName" value="<%= event.EventName %>">

              <label for="EventDescription">Event Description</label>
              <textarea id="EventDescription" name="EventDescription"><%= event.EventDescription %></textarea>

              <label for="EventType">Event Type</label>
              <select id="EventType" name="EventType">
                <% categories.forEach(category => { %>
                  <option value="<%= category.CategoryID %>" <%= category.CategoryID === event.EventType ? "selected" : "" %>><%= category.CategoryName %></option>
                <% }) %>
              </select>

              <div class="form-row">
                <div>
                  <label for="MaxCapacity">Max Capacity</label>
                  <input type="number" id="MaxCapacity" name="MaxCapacity" value="<%= event.MaxCapacity %>">
                </div>
                <div>
                  <label for="EndDateTime">End Date & Time</label>
                  <input type="datetime-local" id="EndDateTime" name="EndDateTime" value="<%= event.EndDateTime.toISOString().slice(0, 16) %>">
                </div>
              </div>

              <label for="Status">Status</label>
              <select id="Status" name="Status">
                <option value="active" <%= event.Status === 'active' ? "selected" : "" %>>Active</option>
                <option value="inactive" <%= event.Status === 'inactive' ? "selected" : "" %>>Inactive</option>
              </select>
            </div>

            <div class="form-actions">
              <button class="btn btn-primary" onClick="updateEvent('<%= event.EventID %>')" type="button">Update Event</button>
              <button class="btn btn-ghost" type="button" onclick="history.back()">Cancel</button>
            </div>
          </div>
        </div>
      </div>
    </div>
</body>
</html>

<script>
    // TODO: Fetch and call patch api to update the event details, then redirect back to the event manage page
    function updateEvent(eventID) {
        let updatedEvent = {
            EventName: document.getElementById("EventName").value,
            EventDescription: document.getElementById("EventDescription").value,
            EventType: document.getElementById("EventType").value,
            MaxCapacity: document.getElementById("MaxCapacity").value,
            EndDateTime: document.getElementById("EndDateTime").value,
            Status: document.getElementById("Status").value
        };

        fetch(`/event/edit/${eventID}`, {
            method: "PATCH",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(updatedEvent)
        })
        .then(async response => {
            const data = await response.json();

            if (response.ok) {
                alert(data.message);
                window.location.href = "/event/manage";
            } else {
                alert(data.message);
            }
        })
        .catch(error => {
            console.error("Error updating event:", error);
            alert("An error occurred while updating the event. Please try again.");
        });
    }
</script>