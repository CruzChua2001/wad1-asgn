<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View and Update Event</title>
</head>
<body>
    <%- include('../partials/navbar') %>

    <h1>View and Update Event</h1>

    <div>
        <input type="hidden" name="_method" value="PATCH">
        <label for="EventName">Event Name:</label><br>
        <input type="text" id="EventName" name="EventName" value="<%= event.EventName %>"><br><br>

        <label for="EventDescription">Event Description:</label><br>
        <textarea id="EventDescription" name="EventDescription"><%= event.EventDescription %></textarea><br><br>

        <!-- change this to select and use ejs for each for categories -->
        <label for="EventType">Event Type:</label><br>
        <select id="EventType" name="EventType" >
            <% categories.forEach(category => { %>
                <option value="<%= category.CategoryID %>" <%= category.CategoryID === event.EventType ? "selected" : "" %>><%= category.CategoryName %></option>
            <% }) %>
        </select><br><br>

        <label for="MaxCapacity">Max Capacity:</label><br>
        <input type="number" id="MaxCapacity" name="MaxCapacity" value="<%= event.MaxCapacity %>"><br><br>

        <button onClick="updateEvent('<%= event.EventID %>')">Update Event</button>
    </div>
</body>
</html>

