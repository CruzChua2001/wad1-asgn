<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View and Update Event</title>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container stack">
      <div class="panel">
        <div class="panel-header row-between">
          <div>
            <h1>View & Update Event</h1>
            <p class="subtle">Make changes and hit Update.</p>
          </div>
          <span class="pill">ID: <%= event.EventID %></span>
        </div>

        <div class="panel-inner grid-2">
          <div>
            <div class="movie-poster event-detail-image">
              <% if (event.EventImage) { %>
                <img src="<%= event.EventImage %>" alt="<%= event.EventName %> poster">
              <% } else { %>
                <div class="event-thumb-placeholder">No Image</div>
              <% } %>
            </div>
            <div>
              <label for="EventImage">Event Image:</label><br>
              <input type="file" id="EventImage" name="EventImage" accept="image/*" value=""><br><br>
            </div>
            <div id="errorMsg">
            </div>

            <div class="approved-participants-section">
              <h3>Approved Participants</h3>
              <% if (typeof approvedParticipants !== 'undefined' && approvedParticipants.length === 0) { %>
                <p>No approved participants.</p>
              <% } else if (typeof approvedParticipants !== 'undefined') { %>
                <table style="width:100%;margin-top:1em;">
                  <thead>
                    <tr>
                      <th>User ID</th>
                      <th>User Name</th>
                      <th>Number of People Booked</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% approvedParticipants.forEach(function(p) { %>
                      <tr>
                        <td><%= p.UserID %></td>
                        <td><%= p.UserName %></td>
                        <td><%= p.numofppl %></td>
                        <td>
                          <button class="btn btn-danger" onclick="cancelReservation('<%= event.EventID %>', '<%= p.ReservationID || p.reservationId %>', '<%= p.numofppl %>')">Cancel</button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              <% } %>
            </div>
            <script>
              async function cancelReservation(eventId, reservationId, numofppl) {
                if (!reservationId) { alert('Reservation ID missing.'); return; }
                if (!confirm('Are you sure you want to cancel this reservation?')) return;
                try {
                  const response = await fetch(`/event/cancel-reservation/${eventId}/${reservationId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ numofppl })
                  });
                  const data = await response.json();
                  if (data.success) {
                    alert('Reservation cancelled. Waitlist (if any) promoted.');
                    location.reload();
                  } else {
                    alert('Error: ' + (data.message || 'Could not cancel.'));
                  }
                } catch (e) {
                  alert('Server error.');
                }
              }
            </script>
          </div>
            
          <div class="form-card stack">
            <div class="stack">
              <label for="EventName">Event Name</label>
              <input type="text" id="EventName" name="EventName" value="<%= event.EventName %>">

              <label for="EventDescription">Event Description</label>
              <textarea id="EventDescription" name="EventDescription"><%= event.EventDescription %></textarea>

              <label for="EventType">Event Type</label>
              <select id="EventType" name="EventType">
                <% categories.forEach(category => { %>
                  <option value="<%= category.CategoryID %>" <%= category.CategoryID === event.EventType ? "selected" : "" %>><%= category.CategoryName %></option>
                <% }) %>
              </select>

              <div class="form-row">
                <div>
                  <label for="MaxCapacity">Max Capacity</label>
                  <input type="number" id="MaxCapacity" name="MaxCapacity" value="<%= event.MaxCapacity %>">
                </div>
                <div>
                  <label for="EndDateTime">End Date & Time</label>
                  <input type="datetime-local" id="EndDateTime" name="EndDateTime" onclick="if (this.showPicker) this.showPicker()" value="<%= event.EndDateTime.toISOString().slice(0, 16) %>">
                </div>
              </div>

              <label for="Status">Status</label>
              <select id="Status" name="Status">
                <option value="active" <%= event.Status === 'active' ? "selected" : "" %>>Active</option>
                <option value="inactive" <%= event.Status === 'inactive' ? "selected" : "" %>>Inactive</option>
              </select>
            </div>

            <div class="form-actions">
              <button class="btn btn-primary" onClick="updateEvent('<%= event.EventID %>')" type="button">Update Event</button>
              <button class="btn btn-ghost" type="button" onclick="history.back()">Cancel</button>
            </div>
          </div>
        </div>
      </div>
    </div>
</body>
</html>

<script>
    // TODO: Fetch and call patch api to update the event details, then redirect back to the event manage page
    async function updateEvent(eventID) {
        const formData = new FormData();
        formData.append("EventName", document.getElementById("EventName").value);
        formData.append("EventDescription", document.getElementById("EventDescription").value);
        formData.append("EventType", document.getElementById("EventType").value);
        formData.append("MaxCapacity", document.getElementById("MaxCapacity").value);
        formData.append("EndDateTime", document.getElementById("EndDateTime").value);
        formData.append("Status", document.getElementById("Status").value);

        const fileInput = document.getElementById("EventImage");
        if (fileInput.files[0]) {
            formData.append("EventImage", fileInput.files[0]);
        }

        //convert fetch to use await and try catch
        try {
            const response = await fetch(`/event/edit/${eventID}`, {
                method: "PATCH",
                body: formData
            });

            const data = await response.json();

            if (response.ok) {
              document.getElementById("errorMsg").innerHTML = ""; // clear old errors
              alert(data.message);
              window.location.href = "/event/manage";
            } else {
                let errorHtml = `<div class="note note-danger"><b>Errors</b><ul>`;
                data.message.forEach(error => {
                  errorHtml += `<li>${error}</li>`;
                });
                errorHtml += `</ul></div>`;
                document.getElementById("errorMsg").innerHTML = errorHtml;  
            }
        } catch (error) {
            console.error("Error updating event:", error);
            alert("An error occurred while updating the event. Please try again.");
        }
    }
</script>