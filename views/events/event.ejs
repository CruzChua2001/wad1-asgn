<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upcoming Events</title>
</head>

<body>
    <%- include('../partials/navbar') %>
        <div class="container stack">
        <div class="row-between">
            <div>
                <h1>Upcoming Events</h1>
                <p class="subtle">Browse through our latest upcoming events.</p>
            </div>
        </div>
        
        <form class="search-row" action="/event" method="GET">
            <input class="search-input" type="text" name="search" placeholder="Search by Event Name..." value="<%= searchTerm || '' %>">
            <button class="btn btn-ghost btn-sm" type="submit">Search</button>
            <a class="btn btn-ghost btn-sm" href="/event">Clear</a>
        </form>

        <br>

        <% if (events.length===0) { %>
            <div class="note center">No matching events</div>
            <% } else { %>

                <div class="event-list">

                    <% events.forEach(event=> { %>
                        <div class="event-card">
                            <div class="event-thumb">
                                <% if(event.EventImage){ %>
                                    <img src="<%= event.EventImage %>" alt="Event Image">
                                <% } else { %>
                                    <div class="event-thumb-placeholder">No Image</div>
                                <% } %>
                            </div>

                                        <div class="event-info">
                                            <h2>
                                                <%= event.EventName %>
                                            </h2>
                                            <div class="meta">
                                                <span class="pill">Type: <%= event.categoryDetails.CategoryName %></span>
                                                <span class="pill">Capacity: <%= event.CurrentCapacity %> / <%= event.MaxCapacity %></span>
                                            </div>
                                            <p><%= event.EventDescription %></p>
                                            <a href="/event/<%= event.EventID %>"><button class="btn btn-primary">View Details</button></a>
                                        </div>
                                </div>
                        <% }) %>
                    </div>
                <% } %>
                </div>

</body>

</html>