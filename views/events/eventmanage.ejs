<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Management</title>
</head>

<body>
    <%- include('../partials/navbar') %>

    <div class="container stack">
        <div class="panel">
          <div class="panel-header">
            <h1>Event Management</h1>
            <p class="subtle">Create, filter, and manage events.</p>
          </div>
          <div class="panel-inner stack">

        <p>
            <a class="btn btn-primary" href="/event/new">Create New Event</a>
        </p>

        <form class="search-row" action="/event/manage" method="GET">
            <input class="search-input" type="text" name="search" placeholder="Search by Event Name..." value="<%= searchTerm %>">
            <button class="btn btn-ghost btn-sm" type="submit">Search</button>
        </form>

        <div class="filter-bar">
            <!-- Type Filter -->
            <!-- Admin can filter events by category (type) -->
            <select id="filterType" class="filter-dropdown">
                <option value="">All Types</option>
                <% categories.forEach(cat=> { %>
                    <option value="<%= cat.CategoryName.toLowerCase() %>">
                        <%= cat.CategoryName %>
                    </option>
                    <% }) %>
            </select>

            <!-- Status Filter -->
            <!-- Filter events by status: 'open' for active events, 'closed' for inactive -->
            <select id="filterStatus" class="filter-dropdown">
                <option value="">All Status</option>
                <option value="open">Open</option>
                <option value="closed">Closed</option>
            </select>

            <!-- Sort Dropdown -->
            <!-- Sort events dynamically by name, current capacity, or date -->
            <select id="sortOption" class="filter-dropdown">
                <option value="">Sort By</option>
                <option value="nameAsc">Name (A → Z)</option>
                <option value="nameDesc">Name (Z → A)</option>
                <option value="capacityAsc">Capacity ↑</option>
                <option value="capacityDesc">Capacity ↓</option>
                <option value="dateAsc">Date ↑</option>
                <option value="dateDesc">Date ↓</option>
            </select>

            <!-- Clear filters, sort, and search results, returning to the default view of all events -->
            <a class="btn btn-ghost btn-sm" href="/event/manage">Clear</a>
        </div>

        <div class="stack">
            <div id="noMatch" class="note center hidden">No matching events</div>
            <div id="eventCards" class="movie-grid">
                <% events.forEach(event=> { %>
                    <!-- Each card stores dataset attributes for filtering and sorting -->
                    <article
                        class="movie-card movie-grid-card manage-event-card"
                        data-type="<%= event.categoryDetails.CategoryName.toLowerCase() %>"
                        data-status="<%= event.Status==='active' ? 'open' : 'closed' %>"
                        data-name="<%= event.EventName %>"
                        data-capacity="<%= event.CurrentCapacity %>"
                        data-date="<%= new Date(event.EndDateTime).toISOString() %>"
                    >
                        <div class="movie-poster">
                            <% if (event.EventImage) { %>
                                <img src="<%= event.EventImage %>" alt="<%= event.EventName %> poster">
                            <% } else { %>
                                <div class="event-thumb-placeholder">No Image</div>
                            <% } %>
                        </div>
                        <div class="movie-body">
                            <h3 class="movie-title"><%= event.EventName %></h3>
                            <div class="movie-meta">
                                <!-- Only displays this for the event manage page -->
                                <span class="pill">Type: <%= event.categoryDetails.CategoryName %></span>
                                <span class="pill">Capacity: <%= event.CurrentCapacity %> / <%= event.MaxCapacity %></span>
                                <span class="pill"><%= event.Status==='active' ? 'Open' : 'Closed' %></span>
                            </div>
                            <div class="movie-desc">
                                <%= event.EventDescription %>
                            </div>
                            <div class="movie-actions">
                                <a class="btn btn-primary btn-sm" href="/event/manage/<%= event.EventID %>">View</a>
                                <button class="btn btn-danger btn-sm" type="button" onClick="deleteEvent('<%= event.EventID %>')">Delete</button>
                            </div>
                        </div>
                    </article>
                <% }) %>
            </div>
        </div>

        <script>
            const deleteEvent = async (eventid) => {
                if (confirm("Are you sure you want to delete this event?")) {
                    try {
                        // Send delete request to server
                        const response = await fetch(`/event/delete/${eventid}`, { method: 'DELETE' });
                        // Check response status
                        if (response.ok) {
                            // If successful: show alert and reload page to update event list
                            alert("Event deleted successfully.");
                            window.location.href = "/event/manage";
                        } else {
                            // If failed: show error alert
                            alert("Failed to delete event.");
                        }
                    } catch (error) {
                        // Handle any network or server errors
                        console.error("Error deleting event:", error);
                        alert("An error occurred while deleting the event.");
                    }
                }
            };

            const filterType = document.getElementById('filterType');
            const filterStatus = document.getElementById('filterStatus');
            const sortOption = document.getElementById('sortOption');
            const noMatch = document.getElementById("noMatch");
            const eventCards = document.getElementById("eventCards");

            const allCards = Array.from(eventCards.querySelectorAll('.manage-event-card'));

            function updateCards() {
                // Get current filter/sort values
                const typeVal = filterType.value.toLowerCase();
                const statusVal = filterStatus.value.toLowerCase();
                const sortVal = sortOption.value;

                const cards = [...allCards];

                // Filter
                // Only show cards that match the event type and status (if any)
                let filtered = cards.filter(card => {
                    const typeText = (card.dataset.type || '').toLowerCase();
                    const statusText = (card.dataset.status || '').toLowerCase();
                    const typeOk = !typeVal || typeText === typeVal;
                    const statusOk = !statusVal || statusText === statusVal;
                    return typeOk && statusOk;
                });

                // Sort the filtered cards based on the selected sort option
                filtered.sort((a, b) => {
                    const nameA = (a.dataset.name || '').toString();
                    const nameB = (b.dataset.name || '').toString();
                    const capA = parseInt(a.dataset.capacity || '0', 10);
                    const capB = parseInt(b.dataset.capacity || '0', 10);
                    const dateA = new Date(a.dataset.date || 0);
                    const dateB = new Date(b.dataset.date || 0);

                    if (sortVal === "nameAsc") return nameA.localeCompare(nameB);
                    if (sortVal === "nameDesc") return nameB.localeCompare(nameA);
                    if (sortVal === "capacityAsc") return capA - capB;
                    if (sortVal === "capacityDesc") return capB - capA;
                    if (sortVal === "dateAsc") return dateA - dateB;
                    if (sortVal === "dateDesc") return dateB - dateA;
                    return 0; // No sorting if no valid option selected
                });

                // Rebuild order
                eventCards.innerHTML = '';
                filtered.forEach(card => eventCards.appendChild(card));

                // Show "No matching events" if filtered array is empty
                noMatch.classList.toggle('hidden', filtered.length > 0);
            }

            // Listen for changes on filters/sort dropdowns
            filterType.addEventListener("change", updateCards);
            filterStatus.addEventListener("change", updateCards);
            sortOption.addEventListener("change", updateCards);

            // Clear filters/sort/search and reset
            function clearFilters() {
                filterType.value = "";
                filterStatus.value = "";
                sortOption.value = "";
                updateCards();
            }

            // Initial render state
            updateCards();
        </script>
</div>
</div>
</div>
</body>

</html>