<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Available Categories</title>
</head>
<body>
    <h2>Event Categories</h2>

    <% if (categoryList.length > 0) { %>
        <ol>
            <% categoryList.forEach(c => { %>
                <li><%= c.CategoryName %> 
                    <form action="/configuration/categoryDetail" method="post">
                        <input type="hidden" name="categoryId" value ="<%= c.CategoryName %>">
                        <input type="submit" value="Details">
                    </form>
                    
                </li>
            <% }) %>
        </ol>
    <% } %>
    <button> <a href="./category/register" style="color: green;">Add a New Category</a></button>
    <% if (isRegister) { %>
        <br><br>
        <form action="./register" method="post">
            <h2>Add a New Category</h2> 
            <label>Category Name: &nbsp;<input type="text" name="categoryName"></label>
            <br><br>
            <% if (missingName) { %>
                <p style="color: red;">Empty Category Name. Try Again! </p>
            <% } else if (isDuplicateCategory) { %>
                <p style="color: red;">Category Name Exists. Try Again! </p>
 
            <% } %>
                
            <input type="submit" value="Add Category">
        </form>
    <% } %>
</body>
</html>