<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pending Reservations</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Pending Reservations</h1>
          <p class="subtle">Approve or reject queued reservations.</p>
        </div>
        <div class="panel-inner stack">
        <% if (reservationOutcome) { %>
             <% if (reservationOutcome.outcome !== "error") { %>
            <div class="note note-success text-success">
                Reservation status <b><%= reservationOutcome.id %></b>
                <b>
                    <%= reservationOutcome.outcome==="R"?"rejected":"" %>
                    <%= reservationOutcome.outcome==="A"?"approved":"" %>
                    <%= reservationOutcome.outcome==="W"?"placed on waitlist":"" %>
                </b>
                successfully.
                <% if (reservationOutcome.outcome==="W") { %>
                    <div class="note note-danger text-danger">This event has reached maximum capacity.</div>
                <% } %>
            </div>
            <% } else if (reservationOutcome.outcome ==="error") { %>
                    <div class="note note-danger text-danger">
                        Database error in updating the reservation status <b><%= reservationOutcome.id %></b>
                        Please try again later.
                    </div>
            <% } %>

    <% } %>

    <% if (!pendingReservations || pendingReservations.length==0) { %>
        <h2>0 reservations in queue</h2>
        <p>Please wait for reservations for events under your allowed categories.</p>
    <% } 
    

    else { %>

        <h2><%= pendingReservations.length %> reservation(s) pending approval</h2>

        
        

        <div class="table-wrap">
        <table>
        
            <tr>
                <th>Event ID</th>
                <th>Event Name</th>
                <th>Reservation User</th>
                <th>Reservation Creation Date</th>
                <th>Pax</th>
                <th>Reservation Outcome?</th>
            </tr>
                <ol>
                <% pendingReservations.forEach(r => { %>
                    
                    
                        <tr>
                            <td><%= r.EventId %></td>
                            <td><%= r.EventName %></td>
                            <td><%= r.UserId %></td>
                            <td><%= r.formattedTime %></td>
                            <td><%= r.numofppl %></td>
                            
                            <td>
                                <form action="/configuration/handle" method="post">
                                    <div class="note note-success">
                                        <label for="approve">Approve
                                            <input type="radio" name="action" id="approve" value="A!<%= r.ReservationID %>">
                                        </label>

                                    </div>
                                    <div>
                                        &nbsp;
                                    </div>
                                    <div class="note note-danger">
                                        <label for="reject">Reject
                                            <input type="radio" name="action" id="reject" value="R!<%= r.ReservationID %>">
                                            
                                        </label>
                                        
                                    </div>
                                    <input type="hidden" name="numPax" value="<%= r.numofppl %>">
                                    <input type="hidden" name="EventId" value="<%= r.EventId %>">
                                    
                                    <br>
                                    <button class="btn btn-primary" type="submit">Confirm Action</button>

                                    
                                </form>
                            </td>
                        </tr>
                        <tr border="hidden">
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                        </tr>
                    
                <% }) %>

                </ol>
        </table>
        </div>
        <% if (missingCategory) { %>
            <div class="note note-danger text-danger">Please click on an Action. Otherwise, please return to Admin Page.</div>

        <% } %>
       <% if (missingCategory) { %>
            <div class="note note-danger text-danger">Please click on an Action. Otherwise, please return to Admin Page.</div>

        <% } %>
    <% } %>
        <a class="btn btn-ghost" href="/configuration">Back to Admin Dashboard</a>
        </div>
      </div>
    </div>

</body>
</html>