<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Approval History</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>

    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h1>Approval History</h1>
          <p class="subtle">A log of reservations you’ve approved.</p>
        </div>
        <div class="panel-inner stack">
    <% if (reservationHistory.length ==0) { %>
        <div class="note">Empty reservation history. You have not approved any reservations yet.</div>
    <% } else if (err) { %>
         <div class="note note-danger text-danger">Error retrieving approved reservations. Please try again later.</div>
    <% } else { %>
         <h2><%= reservationHistory.length %> reservation(s) approved</h2>
         <div class="table-wrap">
         <table>
            <tr>
                <th>Reservation ID</th>
                <th>Event ID</th>
                <th>Event Name</th>
                <th>Reservation User</th>
                <th>Reservation Creation Date</th>
                <th>Pax</th>
                
            </tr>
        
         <% reservationHistory.forEach(r => { %>
            <tr>
                <td><%= r.ReservationID  %></td>
                <td><%= r.EventId %></td>
                <td><%= r.EventName %></td>
                <td><%= r.FullName %></td>
                <td><%= r.formattedTime %></td>
                <td><%= r.numofppl %></td>
                
            </tr>
         <% }) %>
          </table>
          </div>
    <% } %>
    <br>
    <a class="btn btn-ghost" href="/configuration">Back to Admin Dashboard</a>
        </div>
      </div>
    </div>
</body>
</html>