<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Category Outcome</title>
</head>
<body>
    <%- include("../partials/navbar.ejs") %>
    <div class="container stack">
      <div class="panel">
        <div class="panel-header">
          <h2>Category Update Dashboard</h2>
        </div>
        <div class="panel-inner stack">
    <% if (result) { %>
     <div class="note note-success text-success">
        <%- message %>
     </div>
     <% } else { %>
        <div class="note note-danger text-danger">
            <%- message %>
        </div>
    <% } %>
    <a class="btn btn-ghost" href="/configuration/category">Back to Category Dashboard</a>
        </div>
      </div>
    </div>
</body>
</html>